{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "CMake: Configure (clangd)",
      "type": "shell",
      "command": "cmake",
      "args": [
        "--preset",
        "clangd"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": []
    },
    {
      "label": "CMake: Build (clangd)",
      "type": "shell",
      "command": "cmake",
      "args": [
        "--build",
        "--preset",
        "clangd"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "problemMatcher": "$gcc"
    },
    {
      "label": "CTest: Run (clangd)",
      "type": "shell",
      "command": "ctest",
      "args": [
        "--preset",
        "clangd"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "group": "test",
      "problemMatcher": []
    },
    {
      "label": "MWRender: Version",
      "type": "shell",
      "command": "${workspaceFolder}/build/clangd/mwrender.exe",
      "args": [
        "--version"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "dependsOn": "CMake: Build (clangd)",
      "problemMatcher": []
    }
  ]
}

