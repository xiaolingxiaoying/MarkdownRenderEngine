{
  "version": 6,
  "cmakeMinimumRequired": {
    "major": 3,
    "minor": 20,
    "patch": 0
  },
  "configurePresets": [
    {
      "name": "clangd",
      "displayName": "Clangd (MinGW Debug)",
      "description": "Debug build with compile_commands.json for clangd and VS Code.",
      "generator": "MinGW Makefiles",
      "binaryDir": "${sourceDir}/build/clangd",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "CMAKE_CXX_COMPILER": "C:/Program Files/mingw64/bin/g++.exe",
        "CMAKE_EXPORT_COMPILE_COMMANDS": "ON",
        "MWRENDER_BUILD_CLI": "ON",
        "MWRENDER_BUILD_TESTS": "ON"
      }
    },
    {
      "name": "release",
      "displayName": "MinGW Release",
      "generator": "MinGW Makefiles",
      "binaryDir": "${sourceDir}/build/release",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "CMAKE_CXX_COMPILER": "C:/Program Files/mingw64/bin/g++.exe",
        "MWRENDER_BUILD_CLI": "ON",
        "MWRENDER_BUILD_TESTS": "ON"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "clangd",
      "configurePreset": "clangd",
      "jobs": 0
    },
    {
      "name": "release",
      "configurePreset": "release",
      "jobs": 0
    }
  ],
  "testPresets": [
    {
      "name": "clangd",
      "configurePreset": "clangd",
      "output": {
        "outputOnFailure": true
      }
    },
    {
      "name": "release",
      "configurePreset": "release",
      "output": {
        "outputOnFailure": true
      }
    }
  ]
}

