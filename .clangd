CompileFlags:
  CompilationDatabase: build/clangd
  Compiler: C:/Program Files/mingw64/bin/g++.exe
  Add:
    - -Wall
    - -Wextra
    - -Wpedantic
  Remove:
    - -fdiagnostics-color=*

Diagnostics:
  # The public headers intentionally re-export several core AST types. Strict
  # include-cleaner diagnostics are too noisy for this codebase.
  UnusedIncludes: None
  MissingIncludes: None
  ClangTidy:
    Add:
      - bugprone-*
      - performance-*
      - portability-*
    Remove:
      - bugprone-easily-swappable-parameters

Index:
  Background: Build

InlayHints:
  Enabled: true
  ParameterNames: true
  DeducedTypes: true

Hover:
  ShowAKA: true
